def pbExportarPokedexJSON
  require 'json'
  pokedex = []
  mapa_numeros = {}
  indice_regional = 1

  todas_las_especies = []
  GameData::Species.each { |s| todas_las_especies << s }

  # Ordenamos por posición en PBS y luego por forma
  orden_pbs = GameData::Species.keys
  especies_ordenadas = todas_las_especies.sort_by do |s| 
    [orden_pbs.index(s.species), s.form] 
  end

  especies_ordenadas.each do |s|
    next if s.name.nil? || s.name == ""
    
    # --- FILTRO DE FORMAS ESTÉTICAS (ACTUALIZADO) ---
    especie_id = s.species
    forma = s.form
    skip_pokemon = false

    case especie_id
    when :MINIOR
      # Conservamos la forma base (0 - Meteorito) y el Núcleo Rojo (7)
      skip_pokemon = true unless [0, 7].include?(forma)
    when :ALCREMIE, :FLABEBE, :FLORGES, :GENESECT
      # Solo conservamos la forma base (forma 0)
      skip_pokemon = true if forma > 0
    when :FLOETTE
      # Conservamos la forma base (0), la Forma Eterna (5) y tu Mega (6)
      skip_pokemon = true unless [0, 5, 6].include?(forma)
    end

    next if skip_pokemon
    # ----------------------------------

    # Lógica de número regional
    # Asignamos un número nuevo si es la forma 0 de cualquier especie
    if forma == 0
      unless mapa_numeros.key?(especie_id)
        mapa_numeros[especie_id] = indice_regional
        indice_regional += 1
      end
    end
    
    # Si por alguna razón un Pokémon no tiene forma 0 (caso raro), 
    # le asignamos el índice basado en su especie.
    unless mapa_numeros.key?(especie_id)
       mapa_numeros[especie_id] = indice_regional
       indice_regional += 1
    end

    numero_pokedex = mapa_numeros[especie_id] || 0

    pokedex << {
      "numero" => numero_pokedex,
      "id" => s.id.to_s,
      "nombre" => s.name,
      "form_name" => s.form_name || "",
      "es_forma" => s.form > 0,
      "generacion" => s.generation || 0,
      "tipos" => s.types.map { |t| t.to_s },
      "stats_base" => {
        "hp"  => s.base_stats[:HP],
        "atq" => s.base_stats[:ATTACK],
        "def" => s.base_stats[:DEFENSE],
        "spa" => s.base_stats[:SPECIAL_ATTACK],
        "spd" => s.base_stats[:SPECIAL_DEFENSE],
        "vel" => s.base_stats[:SPEED]
      },
      "física" => {
        "altura" => s.height / 10.0,
        "peso" => s.weight / 10.0
      },
      "habilidades" => s.abilities.map { |a| a.to_s },
      "habilidad_oculta" => s.hidden_abilities.map { |a| a.to_s },
      "descripcion" => s.pokedex_entry
    }
  end

  File.open("valerion_data.json", "w") { |f| f.write(JSON.pretty_generate(pokedex)) }
  pbMessage(_INTL("Exportación limpia: se restauraron formas base de Minior y Floette."))
end